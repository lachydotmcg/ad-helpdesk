# AD Helpdesk Cloud Backend -- Environment Variables

# Secret key for Flask sessions
SECRET_KEY=change-this-to-a-long-random-string

# Admin key for tenant management endpoints (POST /admin/tenants)
# Keep this very secure - it allows creating new tenant accounts
ADMIN_KEY=change-this-to-a-long-random-string

# Port to listen on (most cloud platforms set this automatically)
PORT=5000

# Anthropic API key for the AI chat interface (v0.6)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# PostgreSQL connection string (Railway sets this automatically when you add a Postgres plugin)
# Leave blank to use SQLite for local dev
DATABASE_URL=

# SMTP Email Notifications (optional — tickets will work without this)
# When set, Janus emails requesters when their ticket is resolved
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=helpdesk@yourcompany.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=helpdesk@yourcompany.com
