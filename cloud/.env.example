# AD Helpdesk Cloud Backend -- Environment Variables

# Secret key for Flask sessions
SECRET_KEY=change-this-to-a-long-random-string

# Admin key for tenant management endpoints (POST /admin/tenants)
# Keep this very secure - it allows creating new tenant accounts
ADMIN_KEY=change-this-to-a-long-random-string

# Port to listen on (most cloud platforms set this automatically)
PORT=5000
