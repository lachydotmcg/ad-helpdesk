# AD Helpdesk Cloud Backend -- Environment Variables

# Secret key for Flask sessions
SECRET_KEY=change-this-to-a-long-random-string

# Admin key for tenant management endpoints (POST /admin/tenants)
# Keep this very secure - it allows creating new tenant accounts
ADMIN_KEY=change-this-to-a-long-random-string

# Encrypts tenant secrets (SMTP password, Entra client secret) at rest.
# Any passphrase works; generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Without it, those secrets are stored in plaintext. Keep it stable once set.
SETTINGS_ENCRYPTION_KEY=change-this-to-a-long-random-string

# Port to listen on (most cloud platforms set this automatically)
PORT=5000

# --- AI provider ---------------------------------------------------------
# "anthropic" (cloud, default) or "ollama" (fully local, no key, no cost).
AI_PROVIDER=anthropic

# Anthropic API key (only needed when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Ollama settings (only used when AI_PROVIDER=ollama). OLLAMA_URL can point at
# any machine on your network running Ollama, not just localhost.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Local self-host mode ------------------------------------------------
# Set to 1 to run as a single-organisation on-prem install: first start
# provisions one tenant + admin login automatically (no cloud account needed).
AID_LOCAL_MODE=0
AID_LOCAL_ORG=My Organisation
AID_LOCAL_ADMIN_EMAIL=admin@local
AID_LOCAL_ADMIN_PASSWORD=changeme

# PostgreSQL connection string (Railway sets this automatically when you add a Postgres plugin)
# Leave blank to use SQLite for local dev
DATABASE_URL=

# SMTP Email Notifications (optional — tickets will work without this)
# When set, Janus emails requesters when their ticket is resolved
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=helpdesk@yourcompany.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=helpdesk@yourcompany.com

# Stripe billing (optional — get keys from dashboard.stripe.com)
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...  # Your £29/month price ID
