# AD Helpdesk -- Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# IP address of your Windows Server VM
# If using Tailscale (recommended for remote access), use the Tailscale IP
AD_VM_IP=192.168.1.X

# NetBIOS domain name -- this is NOT the FQDN
# e.g. for lab.local the NETBIOS name is LAB
AD_DOMAIN=LAB

# Service account username (without domain prefix)
# Recommended: create a dedicated svc.helpdesk account
AD_ADMIN_USER=svc.helpdesk

# Service account password
AD_ADMIN_PASS=yourpassword

# Web dashboard login password
DASHBOARD_PASSWORD=changeme

# API key for REST API endpoints (X-API-Key header)
API_KEY=changeme

# Flask secret key -- set to any long random string in production
SECRET_KEY=change-this-to-a-long-random-string
